# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pautas
DB_USER=pautas_app
DB_PASSWORD=
DB_MAX_CONNECTIONS=100

# JWT
JWT_SECRET=your-256-bit-secret-change-this-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Google Sheets
GOOGLE_SHEETS_KEY_FILE=./config/service-account-key.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_MANAGER_ACCOUNT_ID=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4200

# Redis (optional - falls back to in-memory if unavailable)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
